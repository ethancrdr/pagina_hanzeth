# WhatsApp Business number in E.164 (no + sign). Used in the post-quiz deep link and the floating button.
NEXT_PUBLIC_WHATSAPP_NUMBER=15550000000

# 4Life store URLs per country. Routed by IP via middleware (request.geo).
NEXT_PUBLIC_FOURLIFE_URL_US=https://us.4life.com/YOUR_ID
NEXT_PUBLIC_FOURLIFE_URL_CO=https://co.4life.com/YOUR_ID
NEXT_PUBLIC_FOURLIFE_URL_ES=https://es.4life.com/YOUR_ID
NEXT_PUBLIC_FOURLIFE_URL_CR=https://cr.4life.com/YOUR_ID
NEXT_PUBLIC_FOURLIFE_URL_DEFAULT=https://www.4life.com/YOUR_ID

# Analytics (client-side scripts; loaded only after cookie consent)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=

# Backend (private, server-side only)
# Google Sheets service account credentials
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_SHEET_ID=
# Resend for email notification
RESEND_API_KEY=
# Where the lead-notification email goes (Hanzeth)
HANZETH_NOTIFY_EMAIL=

# Dev only: override the country detected by middleware
DEV_VISITOR_COUNTRY=CO
